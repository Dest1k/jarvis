# ============================================================================
#  .env.example — пример переменных окружения JARVIS-OS.
#  Скопируйте в .env и при необходимости отредактируйте.
# ============================================================================

# --- LM Studio (этап bootstrap) ---
JARVIS_LMSTUDIO_URL=http://localhost:1234/v1

# --- Лимиты WSL2 ---
JARVIS_WSL_RAM_GB=96
JARVIS_WSL_CPUS=20

# --- Модели (HuggingFace) ---
JARVIS_QWEN_MODEL=Qwen/Qwen2.5-Coder-14B-Instruct-AWQ
JARVIS_UITARS_MODEL=bytedance-research/UI-TARS-2B-SFT

# --- Распределение VRAM ---
JARVIS_QWEN_GPU_UTIL=0.45
JARVIS_QWEN_MAX_LEN=16384
JARVIS_UITARS_GPU_UTIL=0.75

# --- CUDA / vLLM hardening ---
CUDA_VISIBLE_DEVICES=0
CUDA_DEVICE_ORDER=PCI_BUS_ID
CUDA_DISABLE_P2P=1
NCCL_P2P_DISABLE=1

# --- Единый мозг vs отдельное зрение (UI-TARS) ---
JARVIS_ENABLE_UITARS=1
JARVIS_UITARS_URL=http://vllm-ui-tars:8002/v1
JARVIS_UITARS_MODEL_NAME=ui-tars
JARVIS_VISION_MODEL=auto

# --- Замена «мозга»-диспетчера ---
JARVIS_QWEN_DTYPE=half
# JARVIS_QWEN_QUANT_ARGS=
# JARVIS_QWEN_ENFORCE_EAGER=
# JARVIS_UITARS_ENFORCE_EAGER=

# --- Агентский слой (orchestrator) ---
JARVIS_QWEN_OUTPUT_RESERVE=3072
JARVIS_AGENT_MAX_STEPS=10
JARVIS_MEMORY_DIR=/data/memory

# --- Cognitive lifelong learning ---
JARVIS_LIFELONG_LEARNING=0
JARVIS_LEARNING_PAUSE=30
JARVIS_LEARNING_MINE_INCIDENTS=1

# --- Background runtime / GPU guard / self-heal ---
JARVIS_BACKGROUND_RUNTIME=1
JARVIS_IDLE_AFTER_SEC=45
JARVIS_IDLE_INTERVAL_SEC=90
JARVIS_SELF_HEAL_ENABLE=0
JARVIS_SELF_HEAL_APPLY_PATCH=0
JARVIS_REPO_PATH=.
JARVIS_GPU_WARN_MEM_PCT=88
JARVIS_GPU_CRIT_MEM_PCT=94
JARVIS_GPU_WARN_TEMP_C=78
JARVIS_GPU_CRIT_TEMP_C=84
JARVIS_GPU_GUARD_SAMPLE_SEC=8
JARVIS_ALLOW_GPU_POWER_LIMIT=0
JARVIS_GPU_SAFE_POWER_LIMIT_W=420

# --- MCP runtime ---
JARVIS_MCP_RESTART_SEC=20
JARVIS_MCP_START_TIMEOUT=150
JARVIS_MCP_CALL_TIMEOUT=120
JARVIS_MCP_MAX_TOOLS=96
# Read-only mount for Git MCP inside backend container. Relative to wsl/docker-compose.agents.yml.
JARVIS_REPO_GIT_DIR=../.git

# --- Distributed compute cluster (LAN / mesh VPN) ---
JARVIS_CLUSTER_ENABLE=1
JARVIS_CLUSTER_NODES=[]
JARVIS_CLUSTER_TIMEOUT=120
# JARVIS_CLUSTER_NODES=[{"name":"laptop-5080","base_url":"http://192.168.1.50:8001/v1","model":"qwen-coder","role":"coder","transport":"lan","weight":2}]
# JARVIS_CLUSTER_NODES=[{"name":"laptop-5080-tail","base_url":"http://100.x.y.z:8001/v1","model":"qwen-coder","role":"coder","transport":"tailscale","weight":2}]

# --- Safe network resilience ---
JARVIS_NETWORK_RECOVERY_SERVICES=
JARVIS_NETWORK_RECOVERY_CMD=

# --- RPC-мост и git-автоматика ---
JARVIS_GIT_BRANCH=jarvis/auto-updates
JARVIS_ALLOW_PUSH_MAIN=0
JARVIS_HITL_TIMEOUT=180

# --- Перенос на целевой диск (D:\jarvis) ---
JARVIS_TARGET_ROOT=D:\jarvis
JARVIS_DATA_DIR=D:/jarvis/data

# --- HuggingFace токен (если требуется доступ к gated-моделям) ---
HF_TOKEN=
