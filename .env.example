# ============================================================================
#  .env.example — пример переменных окружения JARVIS-OS.
#  Скопируйте в .env и при необходимости отредактируйте.
# ============================================================================

# --- LM Studio (этап bootstrap) ---
JARVIS_LMSTUDIO_URL=http://localhost:1234/v1

# --- Лимиты WSL2 ---
JARVIS_WSL_RAM_GB=96
JARVIS_WSL_CPUS=20

# --- Модели (HuggingFace) ---
JARVIS_QWEN_MODEL=Qwen/Qwen2.5-Coder-14B-Instruct-AWQ
JARVIS_UITARS_MODEL=bytedance-research/UI-TARS-2B-SFT

# --- Распределение VRAM (точный расчёт — в bootstrap_installer.py) ---
# Бюджет 32 GiB: Qwen 14.4 + UI-TARS-2B 6.4 + аудио 2.0 = 22.8 → резерв ~9.2 GiB.
JARVIS_QWEN_GPU_UTIL=0.45
JARVIS_QWEN_MAX_LEN=16384
# ВНИМАНИЕ: util ВТОРОГО vLLM-инстанса (UI-TARS) — КУМУЛЯТИВНЫЙ ПОТОЛОК на всю
# карту (vLLM V1: доступно_под_KV = util×VRAM − уже_занято). Поэтому он ВЫШЕ,
# чем у диспетчера, а не «доля». Низкое значение (0.20) → «No available memory».
JARVIS_UITARS_GPU_UTIL=0.75

# --- CUDA / vLLM hardening ---
# Для Blackwell/WSL2/Docker держим только дискретную NVIDIA-карту видимой для CUDA.
# CUDA_DISABLE_P2P/NCCL_P2P_DISABLE помогают при сбоях вида RuntimeError: UVA is not available
# или при странном peer-to-peer/Unified Virtual Addressing поведении в WSL2.
CUDA_VISIBLE_DEVICES=0
CUDA_DEVICE_ORDER=PCI_BUS_ID
CUDA_DISABLE_P2P=1
NCCL_P2P_DISABLE=1

# --- Единый мозг vs отдельное зрение (UI-TARS) ---
# Инструмент gui/see_screen (визуальное управление экраном) маршрутизируется
# этими ключами. Вкл/выкл сервиса UI-TARS задаёт ФЛАГ ПРОФИЛЯ mono (см.
# wsl/profiles.json) + JARVIS_ENABLE_UITARS; отдельный COMPOSE_PROFILES не нужен.
# КЛАССИКА / ДВОЙНОЙ (по умолчанию): зрение — отдельный UI-TARS, сервис включён.
#   JARVIS_ENABLE_UITARS=1, JARVIS_VISION_MODEL=auto, VISION→UI-TARS (:8002).
# МОНОЛИТ (gemma4-mono / gemma27-mono): единый мультимодальный мозг видит экран
# САМ — отдельный UI-TARS не поднимается. Профиль проставит:
#   JARVIS_ENABLE_UITARS=0
#   JARVIS_UITARS_URL=http://vllm-qwen-coder:8001/v1   (зрение → эндпоинт мозга)
#   JARVIS_UITARS_MODEL_NAME=qwen-coder
#   JARVIS_VISION_MODEL=dispatcher
# Обычно эти ключи задаёт профиль (Пульт → «Профиль системы» или
# `python jarvis.py up --profile gemma4-mono`), править вручную не нужно.
JARVIS_ENABLE_UITARS=1
JARVIS_UITARS_URL=http://vllm-ui-tars:8002/v1
JARVIS_UITARS_MODEL_NAME=ui-tars
JARVIS_VISION_MODEL=auto

# --- Замена «мозга»-диспетчера (Qwen → другая модель) ---
# Управляется кнопкой в Пульте (🧠 Мозг-диспетчер) — обычно править вручную не нужно.
# Тип данных модели: half (fp16) | bfloat16 | auto
JARVIS_QWEN_DTYPE=half
# Аргументы квантования. По умолчанию (если переменная НЕ задана) — AWQ:
#   --quantization awq_marlin
# Для НЕ-AWQ модели (например Gemma в fp16) задайте ПУСТО, чтобы убрать флаг:
#   JARVIS_QWEN_QUANT_ARGS=
# Для другого метода: JARVIS_QWEN_QUANT_ARGS=--quantization awq  (или gptq)
#
# СКОРОСТЬ vs СТАБИЛЬНОСТЬ: по умолчанию vLLM стартует с --enforce-eager
# (надёжно на Blackwell, меньше VRAM). Для ~10-20% более быстрого декодинга
# включите CUDA-графы, ЗАДАВ переменную ПУСТОЙ (убирает флаг). Профиль
# gemma12-tars7 имеет запас VRAM под это:
#   JARVIS_QWEN_ENFORCE_EAGER=
#   JARVIS_UITARS_ENFORCE_EAGER=

# --- Агентский слой (orchestrator) ---
# Резерв токенов под ответ модели; бюджет входа = QWEN_MAX_LEN − этот резерв.
# Держит промпт строго в окне Qwen → нет OOM по контексту/KV-кэшу.
JARVIS_QWEN_OUTPUT_RESERVE=3072
# Максимум шагов ReAct-цикла за один ход (защита от зацикливания).
JARVIS_AGENT_MAX_STEPS=10
# Каталог постоянной памяти агента внутри контейнера (том data/memory).
JARVIS_MEMORY_DIR=/data/memory

# --- Background runtime / GPU guard / self-heal ---
# Фоновый диагностический runtime-loop безопасен по умолчанию: он анализирует состояние,
# но не делает destructive merge/push без отдельной политики и HITL.
JARVIS_BACKGROUND_RUNTIME=1
JARVIS_IDLE_AFTER_SEC=45
JARVIS_IDLE_INTERVAL_SEC=90
JARVIS_SELF_HEAL_ENABLE=0
JARVIS_GPU_WARN_MEM_PCT=88
JARVIS_GPU_CRIT_MEM_PCT=94
JARVIS_GPU_WARN_TEMP_C=78
JARVIS_GPU_CRIT_TEMP_C=84
JARVIS_GPU_GUARD_SAMPLE_SEC=8
JARVIS_ALLOW_GPU_POWER_LIMIT=0
JARVIS_GPU_SAFE_POWER_LIMIT_W=420

# --- Distributed compute cluster (LAN / mesh VPN) ---
# Agent-level offload: внешний ноутбук/сервер сам держит vLLM endpoint, head-node JARVIS
# отправляет туда независимые задачи суб-агентов. Это НЕ tensor/model-splitting по сети.
# Пример LAN:
# JARVIS_CLUSTER_NODES=[{"name":"laptop-5080","base_url":"http://192.168.1.50:8001/v1","model":"qwen-coder","role":"coder","transport":"lan","weight":2}]
# Пример Tailscale/WireGuard: укажите mesh IP/hostname в base_url и transport=tailscale|wireguard.
JARVIS_CLUSTER_NODES=[]
JARVIS_CLUSTER_TIMEOUT=120

# --- Safe network resilience ---
# Диагностика сети работает автоматически. Recovery — только opt-in: перезапуск явно
# разрешённых сервисов или операторский custom hook. Автоподбор DPI-bypass стратегий
# намеренно не реализован.
JARVIS_NETWORK_RECOVERY_SERVICES=
JARVIS_NETWORK_RECOVERY_CMD=

# --- RPC-мост и git-автоматика ---
# Мост КРОСС-ПЛАТФОРМЕННЫЙ: на Windows-хосте использует PowerShell+user32, на
# Linux-хосте — xdotool/ydotool/scrot/xclip (ставятся на хосте: например
#   sudo apt install xdotool scrot xclip wmctrl   # X11
#   sudo apt install ydotool grim wl-clipboard     # Wayland
# Бэкенд выбирается автоматически по ОС — переменных не требует.
#
# Целевая ветка авто-обновлений JARVIS. По умолчанию НЕ main (защита от пуша
# непроверенного ИИ-кода в основную ветку). Чтобы осознанно разрешить main:
#   JARVIS_ALLOW_PUSH_MAIN=1
JARVIS_GIT_BRANCH=jarvis/auto-updates
JARVIS_ALLOW_PUSH_MAIN=0
JARVIS_HITL_TIMEOUT=180

# --- Перенос на целевой диск (D:\jarvis) ---
# Корень проекта и тяжёлых данных. Bootstrap переносит сюда проект, веса
# моделей, кэш HF, WSL-дистрибутив и диск Docker Desktop.
JARVIS_TARGET_ROOT=D:\jarvis
# Каталог тяжёлых данных для bind-mount в docker compose (прямые слэши):
JARVIS_DATA_DIR=D:/jarvis/data

# --- HuggingFace токен (если требуется доступ к gated-моделям) ---
HF_TOKEN=
