# syntax=docker/dockerfile:1
# Dockerfile.audio — аудио-слой JARVIS-OS (Faster-Whisper + Kokoro TTS, GPU).
#
# ВАЖНО (экономия трафика/места): базируемся на ОБРАЗЕ vLLM, в котором уже есть
# torch + CUDA + cuDNN + nvidia-* библиотеки. Их слои ОБЩИЕ с vLLM-сервисами,
# поэтому torch/nvidia НЕ скачиваются и НЕ хранятся повторно. pip ставит только
# небольшие аудио-зависимости и видит torch уже установленным.
ARG JARVIS_VLLM_IMAGE=vllm/vllm-openai:latest
FROM ${JARVIS_VLLM_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    rm -f /etc/apt/apt.conf.d/docker-clean \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        curl ffmpeg libsndfile1 espeak-ng

WORKDIR /app

# Устойчивость pip + зеркало PyPI (см. backend/Dockerfile).
ARG PIP_INDEX_URL=https://pypi.org/simple
ENV PIP_INDEX_URL=${PIP_INDEX_URL} \
    PIP_RETRIES=4 \
    PIP_TIMEOUT=60 \
    PIP_PREFER_BINARY=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# BuildKit-кеш pip: скачанные wheel'ы переживают пересборки → не качаются заново.
COPY requirements.audio.txt ./
RUN --mount=type=cache,target=/root/.cache/pip \
    python3 -m pip install -r requirements.audio.txt

COPY audio_layer.py ./

EXPOSE 8003

HEALTHCHECK --interval=15s --timeout=5s --retries=10 --start-period=90s \
    CMD curl -fsS http://localhost:8003/health || exit 1

# Образ vLLM имеет собственный ENTRYPOINT (API-сервер) — сбрасываем его,
# чтобы запускался наш аудио-сервис.
ENTRYPOINT []
CMD ["uvicorn", "audio_layer:app", "--host", "0.0.0.0", "--port", "8003"]
